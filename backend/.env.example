# Connect to Supabase
DATABASE_URL=
DIRECT_URL=

CLERK_SECRET_KEY=

FINNHUB_API_KEY=

# Trading engine base URL. The engine is the source of truth for live index
# prices (it fetches the upstream itself); this service polls its /index-prices.
# Default http://localhost:9090. If the engine runs in Docker with -p 9090:9090,
# localhost:9090 still reaches it from a host-run backend.
TRADING_ENGINE_URL=http://localhost:9090

# Upstash Redis — backs the index-price rolling history / daily series so the
# backend can run statelessly on serverless (Vercel). Optional: if unset, the
# service falls back to an in-memory store (fine for local dev / always-on
# hosts). Create a free database at https://console.upstash.com (no card).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
