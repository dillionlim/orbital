# Use the official PostgreSQL image
FROM postgres:latest
# Set the environment variables for PostgreSQL, feel free to change them
ENV POSTGRES_USER=postgres
ENV POSTGRES_PASSWORD=postgrespassword
ENV POSTGRES_DB=postgres
# Expose the default PostgreSQL port (postgres listens on 5432; map it at
# runtime with `docker run -p 5432:5432 orbital-db`).
EXPOSE 5432
# Command to run the PostgreSQL server
CMD ["postgres"]