# Copy to .env and fill in:  cp .env.example .env
# scripts/start-private-server.sh sources this file before launching the
# engine, so anything here lands in the engine process's environment.
# Real shell exports still take precedence.

# Sent as `X-Engine-Secret` on POST /api-keys/validate calls to the NestJS
# backend. Backend rejects with 401 if its ENGINE_SHARED_SECRET is set and
# this value doesn't match. Keep both ends in sync.
ORBITAL_ENGINE_SECRET=

# Cap on distinct client_ids tracked per user_id in BotTracker. Without a
# bound, an attacker could rotate through millions of fake client_ids and
# OOM the engine. Default 100 is comfortable for legit multi-strategy users.
# Bump only if you actually need more.
# ORBITAL_MAX_CLIENT_IDS_PER_USER=100

# Gemini API key for the in-process news-driven bots. Optional — if you'd
# rather, drop the key directly into `news.gemini_api_key` in server.json
# (the JSON value wins when both are set). Generate a key at
# https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=
