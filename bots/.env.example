# Copy to .env and fill in:  cp .env.example .env
# Values here are loaded by lib.py on import (and by run_all.sh) before any bot
# script reads its environment. Real exports in your shell still take precedence.

# REQUIRED: API key issued by the backend's /api-keys endpoint.
ORBITAL_API_KEY=sk_live_

# OPTIONAL: where the trading engine lives. Default: ws://localhost:9090/
# ORBITAL_WS=ws://localhost:9090/
